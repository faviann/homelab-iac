#!/bin/sh
set -eu

vmid=$2

case "$1" in
  status)
    echo runtime_refresh >> "$LIFECYCLE_TEST_STATE_DIR/$vmid.events"
    state=$(cat "$LIFECYCLE_TEST_STATE_DIR/$vmid.state")
    if [ "$state" = absent ]; then
      echo "CT $vmid does not exist" >&2
      exit 2
    fi
    echo "status: $state"
    ;;
  config)
    if [ "${LIFECYCLE_WIRING_REAL_ROLES:-}" = 1 ]; then
      echo host_reconciliation >> "$LIFECYCLE_TEST_STATE_DIR/$vmid.events"
    fi
    case "$vmid" in
      7201) echo "hostname: wiring-target" ;;
      7202) echo "hostname: wiring-peer" ;;
      *) echo "hostname: lifecycle-$vmid" ;;
    esac
    ;;
  exec)
    command=$*
    case "$command" in
      *VERSION_ID*)
        echo release_refresh >> "$LIFECYCLE_TEST_STATE_DIR/$vmid.events"
        cat "$LIFECYCLE_TEST_STATE_DIR/$vmid.release"
        ;;
      *CHANGED=*)
        echo access_restoration >> "$LIFECYCLE_TEST_STATE_DIR/$vmid.events"
        echo "CHANGED=1"
        ;;
      *'grep -cxF'*)
        echo 1
        ;;
      *)
        exit 99
        ;;
    esac
    ;;
  *)
    exit 99
    ;;
esac
