# Ansible artifacts
ansible/*.log
ansible/*.retry
ansible/.ansible/
ansible/__pycache__/
ansible/*.pyc

# Ansible collections (installed dependencies)
collections/ansible_collections/
collections/**/*.info/

# External Ansible roles (installed dependencies)
.ansible/roles/

# Ignore local Vault password file
.ansible-vault-pass
.vault-pass
.vault-pass.txt
vault-pass.txt
.vault/
*.retry

# Fact cache
/tmp/ansible_facts/
.ansible/cache/

# Local control node artifacts (portable project setup)
.ansible/venv/
.ansible/vault-pass.txt
.ansible/ssh/
.ansible/cp/
.ansible/tmp/
.ansible/.lock

# Backup files
*.bak
*.backup
*~

# OS files
.DS_Store
Thumbs.db

# direnv
.envrc

# IDE files
.vscode/
.idea/
*.swp
*.swo
.venv/
__pycache__/
*.pyc
*.pyo

# Git worktrees
.worktrees/

# Temporary files
/tmp/

# NOTE: inventory/group_vars/all/vault.yml is intentionally TRACKED. It is safe to commit
# because it is ansible-vault-encrypted with a long random passphrase (see
# rotate-vault-passphrase.sh). Never commit the passphrase or any plaintext secrets.

# Rendered env files (secrets injected at deploy time)
stacks/**/.env

# MCP server config (contains API token)
.mcp.json

# Stack-local secrets and runtime artifacts
stacks/**/secrets/
stacks/portal/homepage-media/appdata/homepage/config/icons/
stacks/portal/homepage-media/appdata/homepage/config/logs/
stacks/portal/homepage-editors/appdata/homepage/config/icons/
stacks/portal/homepage-editors/appdata/homepage/config/logs/
stacks/portal/homepage-admin/appdata/homepage/config/icons/
stacks/portal/homepage-admin/appdata/homepage/config/logs/
