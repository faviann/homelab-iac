# Ansible artifacts
ansible/*.log
ansible/*.retry
ansible/.ansible/
ansible/__pycache__/
ansible/*.pyc

# Ansible collections (installed dependencies)
collections/ansible_collections/
collections/**/*.info/

# External Ansible roles (installed dependencies)
.ansible/roles/

# Ignore local Vault password file
.ansible-vault-pass
.vault-pass
.vault-pass.txt
vault-pass.txt
.vault/
*.retry

# Fact cache
/tmp/ansible_facts/
.ansible/cache/

# Local control node artifacts (portable project setup)
.ansible/venv/
.ansible/vault-pass.txt
.ansible/ssh/
.ansible/cp/
.ansible/.lock

# Backup files
*.bak
*.backup
*~

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
/tmp/
inventory/group_vars/all/vault.yml

# Rendered env files (secrets injected at deploy time)
stacks/**/.env
