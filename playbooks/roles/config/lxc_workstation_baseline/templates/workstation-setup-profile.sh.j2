# Managed by Ansible. Prompts only on interactive SSH logins before setup completes.
if [ "$(id -un 2>/dev/null || printf '')" = "{{ workstation_username }}" ]; then
  export PATH="{{ workstation_home }}/.local/bin:{{ workstation_home }}/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH"
  if [ -r /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
    . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
  fi
  if [ -r "{{ workstation_home }}/.nix-profile/etc/profile.d/hm-session-vars.sh" ]; then
    . "{{ workstation_home }}/.nix-profile/etc/profile.d/hm-session-vars.sh"
  fi
  export PATH="{{ workstation_home }}/.local/bin:{{ workstation_home }}/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH"
fi

_workstation_setup_complete() {
  [ -f "{{ workstation_setup_marker_path }}" ] || return 1
  grep -Fxq "version={{ workstation_setup_version }}" "{{ workstation_setup_marker_path }}" || return 1
}

_workstation_setup_prompt() {
  [ -t 0 ] || return 0
  [ -t 1 ] || return 0
  [ -n "${SSH_CONNECTION:-}${SSH_TTY:-}" ] || return 0
  [ "$(id -un 2>/dev/null || printf '')" = "{{ workstation_username }}" ] || return 0
  [ -z "${WORKSTATION_SETUP_SKIP:-}" ] || return 0
  if _workstation_setup_complete; then
    return 0
  fi
  [ -x "{{ workstation_setup_bin_path }}" ] || return 0

  printf 'Workstation setup has not completed. Run workstation-setup now? [y/N] '
  IFS= read -r _workstation_setup_answer || return 0
  case "$_workstation_setup_answer" in
    y|Y|yes|YES|Yes)
      if "{{ workstation_setup_bin_path }}"; then
        hash -r 2>/dev/null || true
      else
        printf 'workstation-setup did not complete; it will be offered again on your next SSH login.\n' >&2
      fi
      ;;
    *)
      printf 'Skipping workstation-setup; it will be offered again on your next SSH login.\n' >&2
      ;;
  esac
}

_workstation_setup_prompt
{% if workstation_autosync_enabled | bool %}

# Backgrounded dotfiles autosync. Only after setup completes (the prompt above
# owns the pre-marker state, so the two never run at once). Prints reminders
# queued by the PREVIOUS login's sync, then launches a fresh detached run.
_workstation_autosync() {
  [ -n "${SSH_CONNECTION:-}${SSH_TTY:-}" ] || return 0
  [ "$(id -un 2>/dev/null || printf '')" = "{{ workstation_username }}" ] || return 0
  [ -z "${WORKSTATION_SETUP_SKIP:-}" ] || return 0
  _workstation_setup_complete || return 0
  if [ -s "{{ workstation_autosync_notices_path }}" ]; then
    cat "{{ workstation_autosync_notices_path }}"
    : > "{{ workstation_autosync_notices_path }}"
  fi
  if [ ! -x "{{ workstation_update_bin_path }}" ]; then
    printf 'workstation-update is missing or not executable. Run workstation-setup to repair the workstation.\n' >&2
  fi
  [ -x "{{ workstation_autosync_bin_path }}" ] || return 0
  # setsid + </dev/null detaches so login never waits on git/chezmoi.
  setsid "{{ workstation_autosync_bin_path }}" \
    >> "{{ workstation_autosync_log_path }}" 2>&1 < /dev/null &
}
_workstation_autosync
unset -f _workstation_autosync
{% endif %}
unset -f _workstation_setup_prompt
unset -f _workstation_setup_complete
unset _workstation_setup_answer
