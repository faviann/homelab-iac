#!/usr/bin/env bash
# Managed by Ansible. Backgrounded, non-interactive dotfiles autosync.
# Launched detached from the login hook AFTER setup completes. It refreshes the
# chezmoi source and applies dotfiles, but deliberately does LESS than
# workstation-setup: it never runs run_ scripts, never rebuilds home-manager, and
# never unlocks Bitwarden. The two things it can't safely do itself (apply the
# vault-pass secret, rebuild nix) are surfaced as reminders in the notices file,
# which the login hook prints on the next login.
set -euo pipefail
set +x
umask 077

SETUP_VERSION="{{ workstation_setup_version }}"
MARKER_PATH="{{ workstation_setup_marker_path }}"
WORKSTATION_HOME="{{ workstation_home }}"
BW_BIN="{{ workstation_bw_bin_path }}"
SRC="$WORKSTATION_HOME/.local/share/chezmoi"
NOTICES="{{ workstation_autosync_notices_path }}"
STAMP="{{ workstation_autosync_stamp_path }}"
LOCK="{{ workstation_autosync_lock_path }}"
MIN_INTERVAL={{ workstation_autosync_min_interval_seconds }}

# Target paths rendered from bw-reading templates. When bw is locked these are
# skipped and a reminder is queued. Keep this in sync with the dotfiles repo:
# a NEW .tmpl that reads Bitwarden must be added here, else a locked-bw apply
# errors on it (degraded to a non-fatal notice, not a login break).
SECRET_TARGETS=( "$WORKSTATION_HOME/.ansible/vault-pass" )
# Count elements with a loop, not the bash array-length syntax, which collides
# with Jinja's comment-open tag and breaks templating.
secret_count=0
for _s in "${SECRET_TARGETS[@]}"; do secret_count=$((secret_count + 1)); done

export HOME="$WORKSTATION_HOME"
export PATH="$WORKSTATION_HOME/.local/bin:$WORKSTATION_HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

if [ -r /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
  # shellcheck disable=SC1091
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

if [ -r "$WORKSTATION_HOME/.nix-profile/etc/profile.d/hm-session-vars.sh" ]; then
  # shellcheck disable=SC1091
  . "$WORKSTATION_HOME/.nix-profile/etc/profile.d/hm-session-vars.sh"
fi

bw() {
  "$BW_BIN" "$@"
}

status_from_json() {
  python3 -c 'import json,sys; print(json.load(sys.stdin).get("status", ""))'
}

mkdir -p "$(dirname "$NOTICES")"

notice() {
  printf '%s\n' "$*" >> "$NOTICES"
}

# 1. Only after setup is complete. Pre-marker, workstation-setup owns bootstrap
#    and the login hook shows the interactive prompt instead of launching this.
grep -Fxq "version=$SETUP_VERSION" "$MARKER_PATH" 2>/dev/null || exit 0

# 2. Single-flight: bail if another run holds the lock.
exec 9>"$LOCK"
flock -n 9 || exit 0

# 3. Throttle: skip if the last run was under MIN_INTERVAL ago.
now="$(date +%s)"
last="$(cat "$STAMP" 2>/dev/null || echo 0)"
[ $((now - last)) -ge "$MIN_INTERVAL" ] || exit 0
printf '%s' "$now" > "$STAMP"

# 4. Refresh the source (secret-free). Capture the range for drift detection.
#    Non-fatal on network / non-fast-forward failure: degrade to "not synced".
before="$(git -C "$SRC" rev-parse HEAD 2>/dev/null || echo "")"
git -C "$SRC" pull --ff-only --quiet || exit 0
after="$(git -C "$SRC" rev-parse HEAD 2>/dev/null || echo "")"

# 5. Flag heavy changes autosync will NOT apply (nix/home-manager/run_ scripts).
if [ -n "$before" ] && [ "$before" != "$after" ] \
  && git -C "$SRC" diff --name-only "$before" "$after" \
    | grep -Eq '^(flake\.(nix|lock)|home/|\.chezmoiscripts/)'; then
  notice "autosync: nix/flake or install scripts changed — run workstation-setup to rebuild."
fi

# 6. Apply.
#    bw unlocked => full apply (renders vault-pass too; picks up a rotated note).
#    bw locked   => surgical: every managed target EXCEPT the secret targets.
status="$(bw status 2>/dev/null | status_from_json 2>/dev/null || true)"
if [ "$status" = "unlocked" ]; then
  chezmoi apply --exclude=scripts \
    || notice "autosync: apply failed; run workstation-setup."
else
  targets=()
  added=0
  while IFS= read -r target_path; do
    [ -n "$target_path" ] || continue
    for secret in "${SECRET_TARGETS[@]}"; do
      [ "$target_path" = "$secret" ] && continue 2
    done
    targets+=("$target_path")
    added=$((added + 1))
  done < <(chezmoi managed --path-style=absolute --exclude=scripts 2>/dev/null || true)

  if [ "$added" -gt 0 ]; then
    chezmoi apply --exclude=scripts "${targets[@]}" \
      || notice "autosync: apply failed; run workstation-setup."
  fi
  notice "autosync: $secret_count secret(s) skipped (bw locked). Run: chezmoi apply ${SECRET_TARGETS[*]}"
fi
