#!/usr/bin/env bash
set -euo pipefail
set +x
umask 077

SETUP_VERSION="{{ workstation_setup_version }}"
MARKER_PATH="{{ workstation_setup_marker_path }}"
DOTFILES_REPO_URL="{{ workstation_dotfiles_repo_url }}"
GITHUB_CLI_TOKEN_ITEM="{{ workstation_github_cli_token_item }}"
HOME_MANAGER_FLAKE_REF="{{ workstation_home_manager_flake_ref }}"
WORKSTATION_HOME="{{ workstation_home }}"
BW_BIN="{{ workstation_bw_bin_path }}"
MARKER_FINGERPRINT="{{ workstation_setup_version }}|{{ workstation_dotfiles_repo_url }}|{{ workstation_github_cli_token_item }}|{{ workstation_home_manager_flake_ref }}|{{ workstation_bw_bin_path }}"

export HOME="$WORKSTATION_HOME"
export PATH="$WORKSTATION_HOME/.local/bin:$WORKSTATION_HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

if [ -r /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
  # shellcheck disable=SC1091
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

if [ -r "$WORKSTATION_HOME/.nix-profile/etc/profile.d/hm-session-vars.sh" ]; then
  # shellcheck disable=SC1091
  . "$WORKSTATION_HOME/.nix-profile/etc/profile.d/hm-session-vars.sh"
fi

tmpdir=""

cleanup() {
  if [ -n "$tmpdir" ] && [ -d "$tmpdir" ]; then
    rm -rf "$tmpdir"
  fi
}
trap cleanup EXIT

fail() {
  printf 'workstation-setup: %s\n' "$*" >&2
  exit 1
}

bw() {
  "$BW_BIN" "$@"
}

status_from_json() {
  python3 -c 'import json,sys; print(json.load(sys.stdin).get("status", ""))'
}

mode_is_private() {
  case "$(stat -c '%a' "$1")" in
    400|600) return 0 ;;
    *) return 1 ;;
  esac
}

local_secret_files_ready() {
  test -f "$HOME/.ansible/vault-pass" || return 1
  mode_is_private "$HOME/.ansible/vault-pass" || return 1

  test -f "$HOME/.ssh/id_ed25519" || return 1
  mode_is_private "$HOME/.ssh/id_ed25519" || return 1
  test -f "$HOME/.ssh/id_ed25519.pub" || return 1
  test -f "$HOME/.ssh/allowed_signers" || return 1
  test -f "$HOME/.ssh/known_hosts" || return 1
  ssh-keygen -F github.com -f "$HOME/.ssh/known_hosts" >/dev/null || return 1
}

local_bootstrap_ready() {
  local_secret_files_ready || return 1
  test -d "$HOME/.local/share/chezmoi/.git" || return 1
  command -v gh >/dev/null 2>&1 || return 1
  gh auth status --hostname github.com >/dev/null 2>&1 || return 1
}

validate_marker_state() {
  test -f "$MARKER_PATH" || return 1
  grep -Fxq "version=$SETUP_VERSION" "$MARKER_PATH" || return 1
  grep -Fxq "dotfiles=$DOTFILES_REPO_URL" "$MARKER_PATH" || return 1
  grep -Fxq "fingerprint=$MARKER_FINGERPRINT" "$MARKER_PATH" || return 1
  validate_environment >/dev/null 2>&1 || return 1
}

ensure_bitwarden_unlocked() {
  status_json="$(bw status 2>/dev/null || true)"
  status="$(printf '%s' "$status_json" | status_from_json 2>/dev/null || true)"

  if [ "$status" = "unauthenticated" ] || [ -z "$status" ]; then
    printf 'Bitwarden is unauthenticated. Log in to the Bitwarden account used by chezmoi for workstation secrets.\n' >&2
    bw login
    status_json="$(bw status)"
    status="$(printf '%s' "$status_json" | status_from_json)"
  fi

  if [ "$status" = "locked" ]; then
    printf 'Bitwarden is locked. Enter your Bitwarden account password to unlock workstation secrets for this setup run.\n' >&2
    BW_SESSION="$(bw unlock --raw)"
    export BW_SESSION
    test -n "${BW_SESSION:-}" || fail "Bitwarden unlock returned an empty session"
    status_json="$(bw status)"
    status="$(printf '%s' "$status_json" | status_from_json)"
  fi

  test "$status" = "unlocked" || fail "Bitwarden is not unlocked after login/unlock"
  bw sync >/dev/null
}

ensure_chezmoi() {
  if [ ! -d "$HOME/.local/share/chezmoi/.git" ]; then
    chezmoi init --apply "$DOTFILES_REPO_URL"
    return
  fi

  chezmoi update
}

update_chezmoi_source_without_secrets() {
  test -d "$HOME/.local/share/chezmoi/.git" || return 1
  git -C "$HOME/.local/share/chezmoi" pull --ff-only
}

install_setup_dotfiles_without_secrets() {
  update_agent_tools_source="$HOME/.local/share/chezmoi/dot_local/bin/executable_update-agent-tools"
  npmrc_source="$HOME/.local/share/chezmoi/dot_npmrc"

  if [ -f "$update_agent_tools_source" ]; then
    install -m 0755 "$update_agent_tools_source" "$HOME/.local/bin/update-agent-tools"
  fi

  if [ -f "$npmrc_source" ]; then
    install -m 0600 "$npmrc_source" "$HOME/.npmrc"
  fi
}

switch_home_manager() {
  command -v nix >/dev/null 2>&1 || fail "nix missing from PATH"
  rm -f \
    "$WORKSTATION_HOME/.config/systemd/user/default.target.wants/aoe-serve.service" \
    "$WORKSTATION_HOME/.config/systemd/user/sockets.target.wants/aoe-lan-proxy.socket" \
    "$WORKSTATION_HOME/.config/systemd/user/openclaw-gateway.service" \
    "$WORKSTATION_HOME/.config/systemd/user/default.target.wants/openclaw-gateway.service"
  if command -v home-manager >/dev/null 2>&1; then
    home-manager switch -b workstation-setup-backup --flake "$HOME_MANAGER_FLAKE_REF"
  else
    nix run github:nix-community/home-manager -- switch -b workstation-setup-backup --flake "$HOME_MANAGER_FLAKE_REF"
  fi
}

ensure_agent_tools() {
  if [ -x "$WORKSTATION_HOME/.local/bin/codex" ] \
    && [ -x "$WORKSTATION_HOME/.local/bin/claude" ] \
    && [ -x "$WORKSTATION_HOME/.local/bin/pi" ]; then
    return
  fi

  command -v update-agent-tools >/dev/null 2>&1 || fail "update-agent-tools missing from PATH"
  update-agent-tools
  hash -r 2>/dev/null || true
}

authenticate_gh() {
  if gh auth status --hostname github.com >/dev/null 2>&1; then
    return
  fi

  token="$(bw get notes "$GITHUB_CLI_TOKEN_ITEM")" || fail "GitHub CLI token item is missing"
  test -n "$token" || fail "GitHub CLI token item is empty"
  test "$token" != "null" || fail "GitHub CLI token item notes are empty"
  printf '%s\n' "$token" | gh auth login --hostname github.com --with-token >/dev/null
  unset token
}

validate_environment() {
  test -f "$HOME/.ansible/vault-pass" || fail "vault pass missing"
  mode_is_private "$HOME/.ansible/vault-pass" || fail "vault pass must be mode 0400 or 0600"

  test -f "$HOME/.ssh/id_ed25519" || fail "SSH private key missing"
  mode_is_private "$HOME/.ssh/id_ed25519" || fail "SSH private key must be mode 0400 or 0600"
  test -f "$HOME/.ssh/id_ed25519.pub" || fail "SSH public key missing"
  test -f "$HOME/.ssh/allowed_signers" || fail "allowed_signers missing"

  test -f "$HOME/.ssh/known_hosts" || fail "known_hosts missing"
  ssh-keygen -F github.com -f "$HOME/.ssh/known_hosts" >/dev/null \
    || fail "github.com is missing from known_hosts"

  nix --version >/dev/null || fail "nix missing or not working"
  home-manager --version >/dev/null || fail "home-manager missing or not working"
  node --version >/dev/null || fail "node missing or not working"
  npm --version >/dev/null || fail "npm missing or not working"
  uv --version >/dev/null || fail "uv missing or not working"
  jq --version >/dev/null || fail "jq missing or not working"
  rg --version >/dev/null || fail "rg missing or not working"
  fd --version >/dev/null || fail "fd missing or not working"
  fzf --version >/dev/null || fail "fzf missing or not working"
  gh auth status --hostname github.com >/dev/null || fail "gh auth not configured"
  gh api user --jq .login >/dev/null || fail "gh api not working"
  test "$(command -v codex)" = "$WORKSTATION_HOME/.local/bin/codex" \
    || fail "codex must resolve from $WORKSTATION_HOME/.local/bin"
  codex --version >/dev/null || fail "codex missing or not working"
  test "$(command -v claude)" = "$WORKSTATION_HOME/.local/bin/claude" \
    || fail "claude must resolve from $WORKSTATION_HOME/.local/bin"
  claude --version >/dev/null || fail "claude missing or not working"
  test "$(command -v pi)" = "$WORKSTATION_HOME/.local/bin/pi" \
    || fail "pi must resolve from $WORKSTATION_HOME/.local/bin"
  pi --version >/dev/null || fail "pi missing or not working"
  hermes version >/dev/null || fail "hermes missing or not working"
  openclaw --version >/dev/null || fail "openclaw missing or not working"

  ssh_output="$(ssh -o BatchMode=yes -o StrictHostKeyChecking=yes -T git@github.com 2>&1 || true)"
  printf '%s' "$ssh_output" | grep -Eq "successfully authenticated|You've successfully authenticated" \
    || fail "GitHub SSH auth did not report authenticated"

  tmpdir="$(mktemp -d)"
  git -C "$tmpdir" init >/dev/null
  git -C "$tmpdir" config user.name "Workstation Setup Test"
  git -C "$tmpdir" config user.email "workstation-setup@example.invalid"
  git -C "$tmpdir" config gpg.format ssh
  git -C "$tmpdir" config user.signingkey "$HOME/.ssh/id_ed25519.pub"
  git -C "$tmpdir" config commit.gpgsign true
  git -C "$tmpdir" config gpg.ssh.allowedSignersFile "$HOME/.ssh/allowed_signers"
  touch "$tmpdir/test"
  git -C "$tmpdir" add test
  git -C "$tmpdir" commit -m "workstation setup signing test" >/dev/null
  git -C "$tmpdir" log --show-signature -1 >/dev/null
}

write_marker() {
  mkdir -p "$(dirname "$MARKER_PATH")"
  {
    printf 'version=%s\n' "$SETUP_VERSION"
    printf 'dotfiles=%s\n' "$DOTFILES_REPO_URL"
    printf 'fingerprint=%s\n' "$MARKER_FINGERPRINT"
    printf 'completed_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  } > "$MARKER_PATH"
}

if validate_marker_state; then
  exit 0
fi

if ! local_bootstrap_ready; then
  ensure_bitwarden_unlocked
  ensure_chezmoi
else
  if ! update_chezmoi_source_without_secrets; then
    ensure_bitwarden_unlocked
    ensure_chezmoi
  else
    install_setup_dotfiles_without_secrets
  fi
fi
switch_home_manager
ensure_agent_tools
if ! gh auth status --hostname github.com >/dev/null 2>&1; then
  ensure_bitwarden_unlocked
  authenticate_gh
fi
validate_environment
write_marker
printf 'workstation-setup: environment ready.\n'
