#!/usr/bin/env bash
set -euo pipefail
set +x
umask 077

BOOTSTRAP_VERSION="{{ workstation_bootstrap_version }}"
RUN_DIR="{{ workstation_bootstrap_run_dir }}"
ENV_PATH="{{ workstation_bootstrap_env_path }}"
MARKER_PATH="{{ workstation_bootstrap_marker_path }}"
DOTFILES_REPO_URL="{{ workstation_dotfiles_repo_url }}"
GITHUB_CLI_TOKEN_ITEM="{{ workstation_github_cli_token_item }}"
MISE_BIN="{{ workstation_mise_bin }}"
MISE_SHIMS_DIR="{{ workstation_mise_shims_dir }}"
WORKSTATION_HOME="{{ workstation_home }}"
BW_BIN="{{ workstation_bw_bin_path }}"
MARKER_FINGERPRINT="{{ workstation_bootstrap_version }}|{{ workstation_dotfiles_repo_url }}|{{ workstation_github_cli_token_item }}|{{ workstation_mise_bin }}|{{ workstation_mise_shims_dir }}|{{ workstation_bw_bin_path }}"

export HOME="$WORKSTATION_HOME"
export PATH="$MISE_SHIMS_DIR:$WORKSTATION_HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

cleanup() {
  rm -rf "$RUN_DIR"
}
trap cleanup EXIT

fail() {
  printf 'workstation-bootstrap: %s\n' "$*" >&2
  exit 1
}

status_from_json() {
  python3 -c 'import json,sys; print(json.load(sys.stdin).get("status", ""))'
}

validate_marker_state() {
  test -f "$MARKER_PATH" || return 1
  grep -Fxq "version=$BOOTSTRAP_VERSION" "$MARKER_PATH" || return 1
  grep -Fxq "dotfiles=$DOTFILES_REPO_URL" "$MARKER_PATH" || return 1
  grep -Fxq "fingerprint=$MARKER_FINGERPRINT" "$MARKER_PATH" || return 1
  test -f "$HOME/.ansible/vault-pass" || return 1
  test -f "$HOME/.ssh/id_ed25519" || return 1
  test -f "$HOME/.ssh/allowed_signers" || return 1
  test -f "$HOME/.config/mise/config.toml" || return 1
  uv --version >/dev/null || return 1
  gh auth status --hostname github.com >/dev/null || return 1
  codex --version >/dev/null || return 1
  claude --version >/dev/null || return 1
}

# Parse the envelope as data, never as shell.
parse_env_file() {
  BW_CLIENTID=""
  BW_CLIENTSECRET=""
  BW_PASSWORD=""

  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ""|\#*) continue ;;
      BW_CLIENTID=*) BW_CLIENTID="${line#BW_CLIENTID=}" ;;
      BW_CLIENTSECRET=*) BW_CLIENTSECRET="${line#BW_CLIENTSECRET=}" ;;
      BW_PASSWORD=*) BW_PASSWORD="${line#BW_PASSWORD=}" ;;
      *) fail "invalid key or syntax in bootstrap envelope" ;;
    esac
  done < "$ENV_PATH"

  test -n "$BW_CLIENTID" || fail "BW_CLIENTID missing from bootstrap envelope"
  test -n "$BW_CLIENTSECRET" || fail "BW_CLIENTSECRET missing from bootstrap envelope"
  test -n "$BW_PASSWORD" || fail "BW_PASSWORD missing from bootstrap envelope"
  export BW_CLIENTID BW_CLIENTSECRET BW_PASSWORD
}

require_envelope_permissions() {
  test -d "$RUN_DIR" || fail "$RUN_DIR does not exist"
  test -f "$ENV_PATH" || fail "$ENV_PATH does not exist"

  dir_mode="$(stat -c '%a' "$RUN_DIR")"
  file_mode="$(stat -c '%a' "$ENV_PATH")"
  dir_owner="$(stat -c '%U' "$RUN_DIR")"
  file_owner="$(stat -c '%U' "$ENV_PATH")"

  test "$dir_mode" = "700" || fail "$RUN_DIR must be mode 0700"
  test "$file_mode" = "600" || fail "$ENV_PATH must be mode 0600"
  test "$dir_owner" = "{{ workstation_username }}" || fail "$RUN_DIR owner must be {{ workstation_username }}"
  test "$file_owner" = "{{ workstation_username }}" || fail "$ENV_PATH owner must be {{ workstation_username }}"
}

bitwarden_status() {
  "$BW_BIN" status
}

ensure_bitwarden_unlocked() {
  status_json="$(bitwarden_status || true)"
  status="$(printf '%s' "$status_json" | status_from_json 2>/dev/null || true)"

  if [ "$status" = "unauthenticated" ] || [ -z "$status" ]; then
    "$BW_BIN" login --apikey >/dev/null
    status_json="$(bitwarden_status)"
    status="$(printf '%s' "$status_json" | status_from_json)"
  fi

  if [ "$status" = "locked" ]; then
    BW_SESSION="$("$BW_BIN" unlock --passwordenv BW_PASSWORD --raw)"
    export BW_SESSION
    test -n "${BW_SESSION:-}" || fail "Bitwarden unlock returned an empty session"
    status_json="$(bitwarden_status)"
    status="$(printf '%s' "$status_json" | status_from_json)"
  fi

  test "$status" = "unlocked" || fail "Bitwarden is not unlocked after login/unlock"
  "$BW_BIN" sync >/dev/null
}

ensure_chezmoi() {
  if [ ! -d "$HOME/.local/share/chezmoi/.git" ]; then
    for path in \
      "$HOME/.ssh/id_ed25519" \
      "$HOME/.ssh/id_ed25519.pub" \
      "$HOME/.ssh/allowed_signers" \
      "$HOME/.ansible/vault-pass" \
      "$HOME/.config/mise/config.toml"; do
      test ! -e "$path" || fail "$path exists before initial chezmoi apply"
    done
    chezmoi init --apply "$DOTFILES_REPO_URL"
    return
  fi

  test -f "$HOME/.ssh/id_ed25519" || fail "chezmoi initialized but SSH key is missing"
  chezmoi update
}

install_mise_tools() {
  test -x "$MISE_BIN" || fail "mise missing at $MISE_BIN"
  "$MISE_BIN" install node
  "$MISE_BIN" install
  "$MISE_BIN" reshim
}

ensure_github_known_hosts() {
  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"
  touch "$HOME/.ssh/known_hosts"
  chmod 600 "$HOME/.ssh/known_hosts"
  if ! ssh-keygen -F github.com -f "$HOME/.ssh/known_hosts" >/dev/null; then
    ssh-keyscan github.com >> "$HOME/.ssh/known_hosts"
  fi
}

authenticate_gh() {
  token="$("$BW_BIN" get notes "$GITHUB_CLI_TOKEN_ITEM")" || fail "GitHub CLI token item is missing"
  test -n "$token" || fail "GitHub CLI token item is empty"
  test "$token" != "null" || fail "GitHub CLI token item notes are empty"
  printf '%s\n' "$token" | gh auth login --hostname github.com --with-token >/dev/null
  unset token
}

validate_environment() {
  test -f "$HOME/.ansible/vault-pass" || fail "vault pass missing"
  test -f "$HOME/.ssh/id_ed25519" || fail "SSH private key missing"
  test -f "$HOME/.ssh/allowed_signers" || fail "allowed_signers missing"
  test -f "$HOME/.config/mise/config.toml" || fail "mise config missing"

  uv --version >/dev/null
  gh auth status --hostname github.com >/dev/null
  gh api user --jq .login >/dev/null
  codex --version >/dev/null
  claude --version >/dev/null

  ensure_github_known_hosts
  ssh_output="$(ssh -o BatchMode=yes -T git@github.com 2>&1 || true)"
  printf '%s' "$ssh_output" | grep -Eq "successfully authenticated|You've successfully authenticated" \
    || fail "GitHub SSH auth did not report authenticated"

  tmpdir="$(mktemp -d -p "$RUN_DIR" signing.XXXXXX)"
  git -C "$tmpdir" init >/dev/null
  git -C "$tmpdir" config user.name "Bootstrap Test"
  git -C "$tmpdir" config user.email "bootstrap@example.invalid"
  git -C "$tmpdir" config gpg.format ssh
  git -C "$tmpdir" config user.signingkey "$HOME/.ssh/id_ed25519.pub"
  git -C "$tmpdir" config commit.gpgsign true
  git -C "$tmpdir" config gpg.ssh.allowedSignersFile "$HOME/.ssh/allowed_signers"
  touch "$tmpdir/test"
  git -C "$tmpdir" add test
  git -C "$tmpdir" commit -m "bootstrap signing test" >/dev/null
  rm -rf "$tmpdir"
}

write_marker() {
  mkdir -p "$(dirname "$MARKER_PATH")"
  {
    printf 'version=%s\n' "$BOOTSTRAP_VERSION"
    printf 'dotfiles=%s\n' "$DOTFILES_REPO_URL"
    printf 'fingerprint=%s\n' "$MARKER_FINGERPRINT"
    printf 'completed_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  } > "$MARKER_PATH"
}

if validate_marker_state; then
  exit 0
fi

require_envelope_permissions
parse_env_file
ensure_bitwarden_unlocked
ensure_chezmoi
install_mise_tools
authenticate_gh
ensure_github_known_hosts
validate_environment
write_marker