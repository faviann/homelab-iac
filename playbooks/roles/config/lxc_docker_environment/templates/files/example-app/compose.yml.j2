---
# Example Application Docker Compose Configuration
# This demonstrates how to structure additional applications

services:
  example-app:
    image: nginx:alpine
    container_name: example-app
    restart: unless-stopped
    ports:
      - "8080:80"
    volumes:
      - ./html:/usr/share/nginx/html:ro
    environment:
      - NGINX_HOST={{ inventory_hostname }}.faviann.vms
      - NGINX_PORT=80

# This file can be templated with Jinja2 variables
# Place it in files/example-app/ and the role will copy it to the container
