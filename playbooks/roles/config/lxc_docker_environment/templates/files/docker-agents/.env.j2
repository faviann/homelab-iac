{% if traefik_kop_enabled | default(false) %}
{% set portal_host = lxc_docker_env_portal_hosts[0] %}
REDISURL={{ hostvars[portal_host].proxmox_lxc_overrides.hostname | default(portal_host) }}.{{ lxc_dns_domain }}:6379
DOMAIN={{ default_domain }}
{% endif %}
{% if dockhand_hawser_enabled | default(false) %}
DOCKHAND_SERVER_URL={{ dockhand_hawser_server_url }}
TOKEN={{ dockhand_hawser_token | replace('$', '$$') }}
{% endif %}
