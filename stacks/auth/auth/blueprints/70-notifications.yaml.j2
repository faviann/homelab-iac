version: 1
metadata:
  name: repo-auth-notifications
  labels:
    blueprints.goauthentik.io/instantiate: 'true'
    blueprints.goauthentik.io/description: Managed from ServerManagementScripts
entries:
- id: policy-notifiarr-user-events
  model: authentik_policies_expression.expressionpolicy
  state: present
  identifiers:
    name: notifiarr-user-events-filter
  attrs:
    name: notifiarr-user-events-filter
    expression: |-
      ev = request.context.get("event")
      if not ev:
          return False
      if ev.action not in ["model_created", "model_updated", "model_deleted"]:
          return False
      model = ev.context.get("model", {})
      return model.get("app") == "authentik_core" and model.get("model_name") == "user"

# Webhook body mapping
- id: mapping-notifiarr
  model: authentik_events.notificationwebhookmapping
  state: present
  identifiers:
    name: Notifiarr
  attrs:
    name: Notifiarr
    expression: |-
      from authentik.core.models import User as AKUser
      ev = notification.event
      model_ctx = ev.context.get("model", {})
      http_req = ev.context.get("http_request", {})

      summaries = {
          "model_created": "New user created",
          "model_updated": "User updated/activated",
          "model_deleted": "User deleted",
      }
      summary = summaries.get(ev.action, ev.action)

      try:
          u = AKUser.objects.get(pk=model_ctx.get("pk"))
          affected_username = u.username
          affected_email = u.email
          is_active = u.is_active
      except Exception:
          affected_username = f"pk={model_ctx.get('pk')}"
          affected_email = ""
          is_active = None

      performed_by = ev.user.get("username", "?") if isinstance(ev.user, dict) else str(ev.user)

      return {
          "summary": summary,
          "affected_user": affected_username,
          "affected_email": affected_email,
          "is_active": is_active,
          "performed_by": performed_by,
          "client_ip": ev.client_ip,
          "severity": notification.severity,
          "action": ev.action,
          "http_method": http_req.get("method"),
          "http_path": http_req.get("path"),
      }

# Notification transport
- id: transport-notifiarr
  model: authentik_events.notificationtransport
  state: present
  identifiers:
    name: Notifiarr
  attrs:
    name: Notifiarr
    mode: webhook
    webhook_url: {{ auth_notifiarr_webhook_url }}
    webhook_mapping_body: !Find [authentik_events.notificationwebhookmapping, [name, Notifiarr]]
    send_once: false

# Notification rule
- id: rule-user-registration
  model: authentik_events.notificationrule
  state: present
  identifiers:
    name: User Registration
  attrs:
    name: User Registration
    transports:
    - !Find [authentik_events.notificationtransport, [name, Notifiarr]]
    severity: notice
    destination_group: !Find [authentik_core.group, [name, admins]]

- model: authentik_policies.policybinding
  state: present
  identifiers:
    target: !KeyOf rule-user-registration
    order: 0
  attrs:
    target: !KeyOf rule-user-registration
    policy: !Find [authentik_policies_expression.expressionpolicy, [name, notifiarr-user-events-filter]]
    order: 0
    enabled: true
    negate: false
