version: 1
metadata:
  name: repo-auth-oidc-apps
  labels:
    blueprints.goauthentik.io/instantiate: 'false'
    blueprints.goauthentik.io/description: Managed from ServerManagementScripts
entries:
- id: scope-romm-email-verification
  model: authentik_providers_oauth2.scopemapping
  state: present
  identifiers:
    name: RomM Email Verification
  attrs:
    name: RomM Email Verification
    scope_name: email
    description: Ensures RomM receives a verified email claim
    expression: |-
      return {
          "email": user.email,
          "email_verified": True,
      }

- id: scope-reading-apps-email-verification
  model: authentik_providers_oauth2.scopemapping
  state: present
  identifiers:
    name: Reading Apps Email Verification
  attrs:
    name: Reading Apps Email Verification
    scope_name: email
    expression: |-
      return {
          "email": user.email,
          "email_verified": True,
      }

- id: scope-immich-email-verification
  model: authentik_providers_oauth2.scopemapping
  state: present
  identifiers:
    name: Immich Email Verification
  attrs:
    name: Immich Email Verification
    scope_name: email
    description: Ensures Immich receives a verified email claim
    expression: |-
      return {
          "email": user.email,
          "email_verified": True,
      }

- id: scope-admin-apps-email-verification
  model: authentik_providers_oauth2.scopemapping
  state: present
  identifiers:
    name: Admin Apps Email Verification
  attrs:
    name: Admin Apps Email Verification
    scope_name: email
    description: Ensures admin apps receive a verified email claim
    expression: |-
      return {
          "email": user.email,
          "email_verified": True,
      }

- id: provider-romm-public
  model: authentik_providers_oauth2.oauth2provider
  state: present
  identifiers:
    name: romm-public-oidc
  attrs:
    name: romm-public-oidc
    authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
    invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
    property_mappings:
    - !Find [authentik_providers_oauth2.scopemapping, [managed, goauthentik.io/providers/oauth2/scope-openid]]
    - !Find [authentik_providers_oauth2.scopemapping, [managed, goauthentik.io/providers/oauth2/scope-profile]]
    - !KeyOf scope-romm-email-verification
    client_type: confidential
    client_id: romm-public
    client_secret: "{{ stack_vars.romm_oidc_client_secret | replace('$', '$$') }}"
    access_code_validity: minutes=1
    access_token_validity: hours=24
    refresh_token_validity: days=30
    include_claims_in_id_token: true
    signing_key: !Find [authentik_crypto.certificatekeypair, [name, {{ stack_vars.romm_oidc_signing_certificate_name | tojson }}]]
    redirect_uris:
    - matching_mode: strict
      url: https://romm.public.faviann.com/api/oauth/openid
    sub_mode: user_email
    issuer_mode: global

- id: app-romm-public
  model: authentik_core.application
  state: present
  identifiers:
    slug: romm-public
  attrs:
    name: RomM
    slug: romm-public
    provider: !KeyOf provider-romm-public
    policy_engine_mode: any
    launch_url: https://romm.public.faviann.com
    open_in_new_tab: false
    meta_launch_url: ''
    meta_publisher: ''
    meta_description: ''

- model: authentik_policies.policybinding
  state: absent
  identifiers:
    target: !KeyOf app-romm-public
    order: 0

- model: authentik_policies.policybinding
  state: present
  identifiers:
    target: !KeyOf app-romm-public
    order: 1
  attrs:
    target: !KeyOf app-romm-public
    order: 1
    enabled: true
    negate: false
    failure_result: false
    timeout: 30
    group: !Find [authentik_core.group, [name, media]]

- model: authentik_policies.policybinding
  state: present
  identifiers:
    target: !KeyOf app-romm-public
    order: 2
  attrs:
    target: !KeyOf app-romm-public
    order: 2
    enabled: true
    negate: false
    failure_result: false
    timeout: 30
    group: !Find [authentik_core.group, [name, admins]]

