version: 1
metadata:
  name: repo-auth-proxmox-oidc
  labels:
    blueprints.goauthentik.io/instantiate: 'false'
    blueprints.goauthentik.io/description: Managed from ServerManagementScripts
entries:
- id: scope-proxmox-groups
  model: authentik_providers_oauth2.scopemapping
  state: present
  identifiers:
    name: Proxmox Groups
  attrs:
    name: Proxmox Groups
    scope_name: groups
    description: Emits group membership list for Proxmox OIDC group claim mapping
    expression: |-
      return {
          "groups": [group.name for group in user.ak_groups.all()]
      }

- id: provider-proxmox
  model: authentik_providers_oauth2.oauth2provider
  state: present
  identifiers:
    name: proxmox-oidc
  attrs:
    name: proxmox-oidc
    authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
    invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
    property_mappings:
    - !Find [authentik_providers_oauth2.scopemapping, [managed, goauthentik.io/providers/oauth2/scope-openid]]
    - !Find [authentik_providers_oauth2.scopemapping, [managed, goauthentik.io/providers/oauth2/scope-profile]]
    - !Find [authentik_providers_oauth2.scopemapping, [managed, goauthentik.io/providers/oauth2/scope-email]]
    - !KeyOf scope-proxmox-groups
    client_type: confidential
    client_id: proxmox
    client_secret: "{{ stack_vars.proxmox_oidc_client_secret }}"
    access_code_validity: minutes=1
    access_token_validity: hours=24
    refresh_token_validity: days=30
    include_claims_in_id_token: true
    signing_key: !Find [authentik_crypto.certificatekeypair, [name, {{ stack_vars.public_oidc_signing_certificate_name | tojson }}]]
    redirect_uris:
    - matching_mode: strict
      url: https://proxmox.local.faviann.com
    sub_mode: hashed_user_id
    issuer_mode: per_provider

- id: app-proxmox
  model: authentik_core.application
  state: present
  identifiers:
    slug: proxmox
  attrs:
    name: Proxmox VE
    slug: proxmox
    provider: !KeyOf provider-proxmox
    policy_engine_mode: any
    launch_url: https://proxmox.local.faviann.com
    open_in_new_tab: false
    meta_launch_url: ''
    meta_publisher: ''
    meta_description: ''

- model: authentik_policies.policybinding
  state: present
  identifiers:
    target: !KeyOf app-proxmox
    order: 0
  attrs:
    target: !KeyOf app-proxmox
    order: 0
    enabled: true
    negate: false
    failure_result: false
    timeout: 30
    group: !Find [authentik_core.group, [name, PVEAdmins]]
