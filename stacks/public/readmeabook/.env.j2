PUID={{ docker_uid }}
PGID={{ docker_gid }}
TZ=America/Montreal
HOMEPAGE_FQDN={{ stack_name }}.{{ default_domain }}
UMASK=002
LOG_LEVEL=info
JWT_SECRET={{ stack_vars.jwt_secret | replace('$', '$$') }}
JWT_REFRESH_SECRET={{ stack_vars.jwt_refresh_secret | replace('$', '$$') }}
CONFIG_ENCRYPTION_KEY={{ stack_vars.config_encryption_key | replace('$', '$$') }}
POSTGRES_PASSWORD={{ stack_vars.postgres_password | replace('$', '$$') }}
DISABLE_LOCAL_LOGIN=true